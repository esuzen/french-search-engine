@page "/"

<div class="page">
    <div class="lang-toggle">
        <span class="@(lang == "fr" ? "lang-active" : "lang-btn")" @onclick='() => SetLang("fr")'>FR</span>
        <span class="@(lang == "en" ? "lang-active" : "lang-btn")" @onclick='() => SetLang("en")'>EN</span>
    </div>

    <div class="header">
        <h1>@L("title")</h1>
        <p>@L("subtitle")</p>
    </div>

    <div class="dataset-tabs">
        @foreach (var tab in datasetTabs)
        {
            <span class="@(activeTab == tab.Key ? "tab-active" : "tab")" @onclick="() => SetTab(tab.Key)">@tab.Value[lang]</span>
        }
    </div>

    <div class="search-box">
        <span class="search-icon">&#128269;</span>
        <input type="text"
               placeholder="@GetPlaceholder()"
               value="@searchQuery"
               @oninput="OnSearch" />
    </div>

    @if (results != null && results.Count > 0)
    {
        <div class="stats">
            <span>@results.Count @L("results")</span>
            <span>@elapsedMs ms</span>
        </div>

        <div class="results">
            @foreach (var r in results)
            {
                var categoryName = GetCategoryName(r.resultCategory);
                var badgeClass = GetBadgeClass(r.resultCategory);
                var barColor = GetBarColor(r.resultCategory);

                <div class="result-card">
                    <div>
                        <div class="result-name">@GetDisplayName(r.objectValue)</div>
                        <div class="result-detail">@GetDisplayDetail(r.objectValue)</div>
                    </div>
                    <span class="badge @badgeClass">@categoryName</span>
                    <div class="similarity">
                        <div class="similarity-bar">
                            <div class="similarity-fill" style="width: @((int)r.percentageSimilarity)%; background: @barColor;"></div>
                        </div>
                        <span class="similarity-value">@((int)r.percentageSimilarity)%</span>
                    </div>
                </div>
            }
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(searchQuery))
    {
        <div class="empty-state">
            <div class="icon">&#128528;</div>
            <p>@L("no_results") "<strong>@searchQuery</strong>"</p>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="icon">&#9650;</div>
            <p>@GetEmptyText()</p>
        </div>
    }

    <div class="examples">
        <h3>@L("try_examples")</h3>
        <div class="example-chips">
            @foreach (var example in GetExamples())
            {
                <span class="chip" @onclick="() => SetQuery(example)">@example</span>
            }
        </div>
    </div>

    <div class="footer">
        <p>@L("powered_by") <a href="https://github.com/esuzen/french-search-engine" target="_blank">SearchModule.French</a> @L("powered_wasm")</p>
    </div>
</div>
